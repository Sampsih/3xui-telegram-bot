#!/usr/bin/env bash
set -Eeuo pipefail

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export PATH

install -d -m 0755 /run/lock
lock_file=/run/lock/xui-panel-update.lock
if command -v flock >/dev/null 2>&1; then
  exec 9>"$lock_file"
  if ! flock -n 9; then
    echo 'Another panel update is already running' >&2
    exit 75
  fi
else
  lock_directory=${lock_file}.d
  if ! mkdir "$lock_directory" 2>/dev/null; then
    echo 'Another panel update is already running' >&2
    exit 75
  fi
  trap 'rmdir "$lock_directory" 2>/dev/null || true' EXIT
fi

backup_dir=/var/backups/x-ui
install -d -m 0700 "$backup_dir"
stamp=$(date -u +%Y%m%dT%H%M%SZ)

printf 'Installed before update: '
/usr/local/x-ui/x-ui -v 2>/dev/null || echo unknown

if [[ -f /etc/x-ui/x-ui.db ]]; then
  install -m 0600 -o root -g root /etc/x-ui/x-ui.db "$backup_dir/x-ui-$stamp.db"
fi

# The installed 3x-ui version decides whether this command is non-interactive.
# Test it manually before enabling the Mini App update button.
if command -v x-ui >/dev/null 2>&1; then
  x-ui update
elif [[ -x /usr/local/x-ui/x-ui ]]; then
  /usr/local/x-ui/x-ui update
else
  echo 'x-ui executable not found' >&2
  exit 127
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl is-active --quiet x-ui
elif command -v rc-service >/dev/null 2>&1; then
  rc-service x-ui status >/dev/null
elif command -v service >/dev/null 2>&1; then
  service x-ui status >/dev/null
else
  echo 'No supported service manager found (systemctl, rc-service, service)' >&2
  exit 69
fi
printf 'Installed after update: '
/usr/local/x-ui/x-ui -v 2>/dev/null || echo unknown
echo '__PANEL_HEALTH__=active'
