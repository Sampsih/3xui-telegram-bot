#!/usr/bin/env bash
set -Eeuo pipefail

exec 9>/run/lock/xui-panel-update.lock
if ! flock -n 9; then
  echo 'Another panel update is already running' >&2
  exit 75
fi

backup_dir=/var/backups/x-ui
/usr/bin/install -d -m 0700 "$backup_dir"
stamp=$(date -u +%Y%m%dT%H%M%SZ)

printf 'Installed before update: '
/usr/local/x-ui/x-ui -v 2>/dev/null || echo unknown

if [[ -f /etc/x-ui/x-ui.db ]]; then
  /usr/bin/install -m 0600 -o root -g root /etc/x-ui/x-ui.db "$backup_dir/x-ui-$stamp.db"
fi

# The installed 3x-ui version decides whether this command is non-interactive.
# Test it manually before enabling the Mini App update button.
if command -v x-ui >/dev/null 2>&1; then
  x-ui update
elif [[ -x /usr/local/x-ui/x-ui ]]; then
  /usr/local/x-ui/x-ui update
else
  echo 'x-ui executable not found' >&2
  exit 127
fi

/usr/bin/systemctl is-active --quiet x-ui
printf 'Installed after update: '
/usr/local/x-ui/x-ui -v 2>/dev/null || echo unknown
echo '__PANEL_HEALTH__=active'
