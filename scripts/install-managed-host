#!/usr/bin/env bash
set -Eeuo pipefail

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export PATH

if [[ ${EUID:-$(id -u)} -ne 0 ]]; then
  echo 'Run this script as root on the managed 3x-ui server' >&2
  exit 1
fi

public_key_file=${1:-}
if [[ -z "$public_key_file" || ! -f "$public_key_file" ]]; then
  echo 'Usage: install-managed-host /path/to/xuiadmin_id_ed25519.pub' >&2
  exit 2
fi

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
for required in xui-system-update xui-safe-update xuiadmin.sudoers; do
  if [[ ! -f "$script_dir/$required" ]]; then
    echo "Missing $script_dir/$required" >&2
    exit 3
  fi
done

for required_command in getent grep install useradd visudo; do
  if ! command -v "$required_command" >/dev/null 2>&1; then
    echo "Required command is missing: $required_command" >&2
    exit 69
  fi
done

if ! id xuiadmin >/dev/null 2>&1; then
  login_shell=$(command -v bash || command -v sh)
  useradd -m -s "$login_shell" xuiadmin
fi
if getent group systemd-journal >/dev/null 2>&1 && command -v usermod >/dev/null 2>&1; then
  usermod -aG systemd-journal xuiadmin
fi

user_home=$(getent passwd xuiadmin | awk -F: '{print $6}')
user_group=$(id -gn xuiadmin)
if [[ -z "$user_home" || "$user_home" == '/' ]]; then
  echo 'Could not determine a safe home directory for xuiadmin' >&2
  exit 70
fi

install -d -m 0700 -o xuiadmin -g "$user_group" "$user_home/.ssh"
touch "$user_home/.ssh/authorized_keys"
chown xuiadmin:"$user_group" "$user_home/.ssh/authorized_keys"
chmod 0600 "$user_home/.ssh/authorized_keys"

public_key=$(<"$public_key_file")
if [[ -z "$public_key" || "$public_key" != ssh-* ]]; then
  echo 'The supplied file does not look like an OpenSSH public key' >&2
  exit 4
fi
if ! grep -qxF "$public_key" "$user_home/.ssh/authorized_keys"; then
  printf '%s\n' "$public_key" >> "$user_home/.ssh/authorized_keys"
fi

install -m 0755 -o root -g root "$script_dir/xui-system-update" /usr/local/sbin/xui-system-update
install -m 0755 -o root -g root "$script_dir/xui-safe-update" /usr/local/sbin/xui-safe-update
install -d -m 0755 /etc/sudoers.d
visudo -cf "$script_dir/xuiadmin.sudoers"
install -m 0440 -o root -g root "$script_dir/xuiadmin.sudoers" /etc/sudoers.d/xuiadmin
visudo -cf /etc/sudoers.d/xuiadmin

package_manager=$(/usr/local/sbin/xui-system-update --check | sed -n 's/^__PACKAGE_MANAGER__=//p')
echo "Managed-host prerequisites installed successfully (package manager: $package_manager)."
echo 'Verify from the management host with: ssh xuiadmin@HOST sudo -n -l'
