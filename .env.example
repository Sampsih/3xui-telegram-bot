# Public URL of this application
APP_DOMAIN=xui-admin.example.com
MINI_APP_URL=https://xui-admin.example.com/app/

# Telegram
BOT_TOKEN=123456789:replace_me
ALLOWED_TELEGRAM_IDS=[123456789]
AUTH_MAX_AGE_SECONDS=900
BOT_OUTPUT_MAX_CHARS=12000

# Application security and operations
DEV_BYPASS_AUTH=false
ENABLE_API_DOCS=false
MAX_REQUEST_BODY_BYTES=65536
BACKUP_RETENTION_DAYS=30
SERVER_PROBE_CONCURRENCY=10
DATA_DIR=/data

# Scalable server inventory. Legacy SERVERS=[...] remains supported, but do
# not configure SERVERS and SERVERS_FILE at the same time.
SERVERS_FILE=/config/servers.json

# The interactive installer sets this automatically when at least one panel
# is reachable only through SSH.
# COMPOSE_FILE=docker-compose.yml:docker-compose.tunnel.yml

# Secrets referenced from config/servers.json
SERVER1_PANEL_API_TOKEN=replace_me
SERVER2_PANEL_USERNAME=admin
SERVER2_PANEL_PASSWORD=replace_me

# Optional SSH tunnel compose overlay
TUNNEL_SSH_HOST=203.0.113.20
TUNNEL_SSH_PORT=22
TUNNEL_SSH_USER=xuiadmin
TUNNEL_SSH_KEY_FILE=id_ed25519_tunnel
TUNNEL_LOCAL_PORT=28481
TUNNEL_REMOTE_PORT=28481
